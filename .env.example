# NaiaTrade — Environment Variables
# Copy to .env and fill in your values.
# NEVER commit .env to git.

# Exchange
BINANCE_API_KEY=your_testnet_api_key
BINANCE_SECRET_KEY=your_testnet_secret_key
BINANCE_TESTNET=true

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=naiatrade
POSTGRES_USER=naiatrade
POSTGRES_PASSWORD=change_me

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# LLM
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_MODEL=deepseek-chat

# External APIs
GLASSNODE_API_KEY=your_glassnode_api_key
DEFILLAMA_API_KEY=          # Optional, free tier
CRYPTOQUANT_API_KEY=        # Optional
ALTERNATIVE_ME_API_KEY=     # Optional, free tier
COINGECKO_API_KEY=          # Optional, free tier

# Telegram Alerts
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Environment
ENVIRONMENT=development     # development | paper | live
LOG_LEVEL=INFO
